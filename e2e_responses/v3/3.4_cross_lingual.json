          },
          {
            "block_id": "#/texts/727",
            "block_type": "heading",
            "page": 1,
            "snippet_original": "4.3.1 Các chỉ số đánh giá: MAE, RMSE, WAPE và R²",
            "source_language": "vi",
            "bbox": null,
            "confidence": null,
            "material_id": "6a0ed9eb455165de1b01120e",
            "doc_name": "DeAn_ST-TopoKAN_final_ready.docx",
            "audio_start_seconds": null,
            "audio_end_seconds": null,
            "audio_file": null
          },
          {
            "block_id": "#/texts/728",
            "block_type": "paragraph",
            "page": 1,
            "snippet_original": "Khi đánh giá, toàn bộ dự báo trên tập kiểm thử được chuyển về đơn vị kW trước khi tính chỉ số. Bốn chỉ số WAPE, MAE, RMSE và R² được tính cho từng mốc dự báo, tạo cùng một nền đối sánh giữa các kiến trúc mô hình.",
            "source_language": "vi",
            "bbox": null,
            "confidence": null,
            "material_id": "6a0ed9eb455165de1b01120e",
            "doc_name": "DeAn_ST-TopoKAN_final_ready.docx",
            "audio_start_seconds": null,
            "audio_end_seconds": null,
            "audio_file": null
          },
          {
            "block_id": "#/texts/729",
            "block_type": "paragraph",
            "page": 1,
            "snippet_original": "WAPE được chọn làm chỉ số chính thay vì MAPE vì dữ liệu phụ tải có những đoạn bằng 0 hoặc gần 0. Ở MAPE, sai số tại mỗi thời điểm được chia cho giá trị thực tế của chính thời điểm đó; khi phụ tải nhỏ, tỷ lệ sai số dễ tăng mạnh và làm sai lệch giá trị trung bình. WAPE cộng sai số theo độ lớn trên toàn tập kiểm thử rồi chuẩn hóa bằng tổng phụ tải thực tế [5], [6], [31]. Vì vậy, WAPE phù hợp hơn với chuỗi có giá trị bằng 0 và phản ánh sai số theo quy mô vận hành của cụm.",
            "source_language": "vi",
            "bbox": null,
            "confidence": null,
            "material_id": "6a0ed9eb455165de1b01120e",
            "doc_name": "DeAn_ST-TopoKAN_final_ready.docx",
            "audio_start_seconds": null,
            "audio_end_seconds": null,
            "audio_file": null
          },
          {
            "block_id": "#/texts/730",
            "block_type": "equation",
            "page": 1,
            "snippet_original": "WAPE=\\frac{\\sum_{i=1}^{N}\\left|y_{i}-^_{i}\\right|}{\\sum_{i=1}^{N}\\left|y_{i}\\right|} \\text{ \\texttimes } 100 \\%",
            "source_language": "vi",
            "bbox": null,
            "confidence": null,
            "material_id": "6a0ed9eb455165de1b01120e",
            "doc_name": "DeAn_ST-TopoKAN_final_ready.docx",
            "audio_start_seconds": null,
            "audio_end_seconds": null,
            "audio_file": null
          },
          {
            "block_id": "#/texts/731",
            "block_type": "paragraph",
            "page": 1,
            "snippet_original": "MAE cho biết sai lệch trung bình theo đơn vị kW, dễ đọc khi trao đổi với kỹ sư vận hành.",
            "source_language": "vi",
            "bbox": null,
            "confidence": null,
            "material_id": "6a0ed9eb455165de1b01120e",
            "doc_name": "DeAn_ST-TopoKAN_final_ready.docx",
            "audio_start_seconds": null,
            "audio_end_seconds": null,
            "audio_file": null
          },
          {
            "block_id": "#/texts/732",
            "block_type": "equation",
            "page": 1,
            "snippet_original": "MAE=\\frac{1}{N}\\sum_{i=1}^{N}\\left|y_{i}-^_{i}\\right|",
            "source_language": "vi",
            "bbox": null,
            "confidence": null,
            "material_id": "6a0ed9eb455165de1b01120e",
            "doc_name": "DeAn_ST-TopoKAN_final_ready.docx",
            "audio_start_seconds": null,
            "audio_end_seconds": null,
            "audio_file": null
          },
          {
            "block_id": "#/texts/733",
            "block_type": "paragraph",
            "page": 1,
            "snippet_original": "RMSE nhạy hơn với sai số lớn, nên hữu ích khi kiểm tra các lần dự báo trượt đỉnh tải hoặc đáy tải.",
            "source_language": "vi",
            "bbox": null,
            "confidence": null,
            "material_id": "6a0ed9eb455165de1b01120e",
            "doc_name": "DeAn_ST-TopoKAN_final_ready.docx",
            "audio_start_seconds": null,
            "audio_end_seconds": null,
            "audio_file": null
          }
        ]
      },
      {
        "doc_id": "6a0ed9eb455165de1b01120e",
        "doc_name": "DeAn_ST-TopoKAN_final_ready.docx",
        "page": 1,
        "pages": [
          1
        ],
        "block_id": "#/texts/639",
        "block_type": "list",
        "snippet_original": "Thành phần gần WAPE đưa thước đo chính của báo cáo vào quá trình học. Mô hình không chỉ học theo MAE hoặc MSE mà còn bám gần hơn với cách đánh giá cuối cùng.",
        "snippet_translated": null,
        "bbox": null,
        "role": "supporting",
        "source_language": "mixed",
        "confidence": 0.547942263053346,
        "evidence_blocks": [
          {
            "block_id": "#/texts/638",
            "block_type": "paragraph",
            "page": 1,
            "snippet_original": "Biên an toàn nhỏ hỗ trợ mô hình ở mốc gần, nhưng không đặt quá lớn để tránh dự báo bị đẩy lên trên.",
            "source_language": "vi",
            "bbox": null,
            "confidence": null,
            "material_id": "6a0ed9eb455165de1b01120e",
            "doc_name": "DeAn_ST-TopoKAN_final_ready.docx",
            "audio_start_seconds": null,
            "audio_end_seconds": null,
            "audio_file": null
          },
          {
            "block_id": "#/texts/639",
            "block_type": "list",
            "page": 1,
            "snippet_original": "Thành phần gần WAPE đưa thước đo chính của báo cáo vào quá trình học. Mô hình không chỉ học theo MAE hoặc MSE mà còn bám gần hơn với cách đánh giá cuối cùng.",
            "source_language": "vi",
            "bbox": null,
            "confidence": null,
            "material_id": "6a0ed9eb455165de1b01120e",
            "doc_name": "DeAn_ST-TopoKAN_final_ready.docx",
            "audio_start_seconds": null,
            "audio_end_seconds": null,
            "audio_file": null
          },
          {
            "block_id": "#/texts/640",
            "block_type": "equation",
            "page": 1,
            "snippet_original": "L_{W}=\\frac{\\sum_{i}^{}\\left|e_{i}\\right|}{\\sum_{i}^{}\\left|y_{i}\\right|+ \\varepsilon }",
            "source_language": "vi",
            "bbox": null,
            "confidence": null,
            "material_id": "6a0ed9eb455165de1b01120e",
            "doc_name": "DeAn_ST-TopoKAN_final_ready.docx",
            "audio_start_seconds": null,
            "audio_end_seconds": null,
            "audio_file": null
          },
          {
            "block_id": "#/texts/641",
            "block_type": "paragraph",
            "page": 1,
            "snippet_original": "Trong tính toán, mẫu số của WAPE được cộng thêm một hằng số nhỏ để tránh lỗi chia cho 0 ở các đoạn phụ tải gần 0.",
            "source_language": "vi",
            "bbox": null,
            "confidence": null,
            "material_id": "6a0ed9eb455165de1b01120e",
            "doc_name": "DeAn_ST-TopoKAN_final_ready.docx",
            "audio_start_seconds": null,
            "audio_end_seconds": null,
            "audio_file": null
          },
          {
            "block_id": "#/texts/642",
            "block_type": "list",
            "page": 1,
            "snippet_original": "Trọng số đỉnh tuyến tính làm tăng trọng số cho các điểm phụ tải cao. Trong bài toán điều độ, sai số ở giờ đỉnh tải thường đáng chú ý hơn sai số cùng độ lớn ở giờ thấp điểm.",
            "source_language": "vi",
            "bbox": null,
            "confidence": null,
            "material_id": "6a0ed9eb455165de1b01120e",
            "doc_name": "DeAn_ST-TopoKAN_final_ready.docx",
            "audio_start_seconds": null,
            "audio_end_seconds": null,
            "audio_file": null
          },
          {
            "block_id": "#/texts/643",
            "block_type": "equation",
            "page": 1,
            "snippet_original": "L_{P}=\\frac{1}{N}\\sum_{i}^{}max\\left(y_{i},0\\right) \\cdot \\left|e_{i}\\right|",
            "source_language": "en",
            "bbox": null,
            "confidence": null,
            "material_id": "6a0ed9eb455165de1b01120e",
            "doc_name": "DeAn_ST-TopoKAN_final_ready.docx",
            "audio_start_seconds": null,
            "audio_end_seconds": null,
            "audio_file": null
          },
          {
            "block_id": "#/texts/644",
            "block_type": "paragraph",
            "page": 1,
            "snippet_original": "Thành phần này dùng giá trị phụ tải thực tế làm hệ số nhân cho độ lệch dự báo. Nhờ đó, mô hình chú ý hơn tới đỉnh tải mà không cần đặt một ngưỡng thủ công cố định.",
            "source_language": "vi",
            "bbox": null,
            "confidence": null,
            "material_id": "6a0ed9eb455165de1b01120e",
            "doc_name": "DeAn_ST-TopoKAN_final_ready.docx",
            "audio_start_seconds": null,
            "audio_end_seconds": null,
            "audio_file": null
          },
          {
            "block_id": "#/texts/646",
            "block_type": "list",
            "page": 1,
            "snippet_original": "Độ mượt và độ cong được thêm để tránh đường dự báo dao động quá gấp. Trong thực tế, một đường dự báo liên tục và ít dao động đột ngột hữu ích hơn cho kỹ sư vận hành so với chuỗi điểm thay đổi mạnh giữa hai mốc liên tiếp.",
            "source_language": "vi",
            "bbox": null,
            "confidence": null,
            "material_id": "6a0ed9eb455165de1b01120e",
            "doc_name": "DeAn_ST-TopoKAN_final_ready.docx",
            "audio_start_seconds": null,
            "audio_end_seconds": null,
            "audio_file": null
          }
        ]
      },
      {
        "doc_id": "6a0ed9eb455165de1b01120e",
