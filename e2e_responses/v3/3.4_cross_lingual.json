            "block_type": "heading",
            "page": 1,
            "snippet_original": "2.1.3 Bối cảnh thực tiễn tại Việt Nam và Điện lực Tây Ninh",
            "source_language": "vi",
            "bbox": null,
            "confidence": null,
            "material_id": "6a0ed9eb455165de1b01120e",
