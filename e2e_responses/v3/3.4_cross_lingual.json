          },
          {
            "block_id": "#/texts/299",
            "block_type": "paragraph",
            "page": 1,
            "snippet_original": "Nghiên cứu sử dụng dữ liệu thực tế của cụm trạm biến áp Tân Hưng, tỉnh Tây Ninh, từ ngày 09/02/2020 đến 31/12/2025. Khoảng thời gian này bao gồm ngày làm việc, ngày nghỉ, mùa khô, mùa mưa, dịp lễ/Tết và một số giai đoạn biến động kinh tế - xã hội. Việc tập trung vào MBA 224 Tân Hưng và bốn trạm liên quan làm cho bài toán có phạm vi cụ thể, đồng thời vẫn phản ánh nhiều tình huống vận hành thực tế.",
            "source_language": "vi",
            "bbox": null,
            "confidence": null,
