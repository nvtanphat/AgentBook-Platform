            "block_type": "equation",
            "page": 1,
            "snippet_original": "y_{j}=\\sum_{i=1}^{n_{in}}\\left[W_{ji}^{\\left(b\\right)}GELU\\left(x_{i}\\right)+\\sum_{k=1}^{G+p}c_{jik}B_{k,p}\\left(x_{i}\\right)\\right]",
