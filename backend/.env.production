# ── App ───────────────────────────────────────────────────────────────────────
AGENTBOOK_APP_ENV=production

# ── Auth (bắt buộc khi APP_ENV=production) ────────────────────────────────────
# Dùng làm JWT signing secret — đặt chuỗi random >= 32 ký tự
API_KEY=CHANGE_ME_RANDOM_SECRET_32CHARS
API_AUTH_ENABLED=true

# ── Database ───────────────────────────────────────────────────────────────────
MONGODB_URI=mongodb+srv://user:password@cluster/agentbook?retryWrites=true&w=majority
AGENTBOOK_MONGODB_DATABASE=agentbook

# ── Vector store ───────────────────────────────────────────────────────────────
AGENTBOOK_QDRANT_URL=http://qdrant:6333

# ── Task queue ─────────────────────────────────────────────────────────────────
AGENTBOOK_REDIS_URL=redis://redis:6379/0
AGENTBOOK_CELERY_BROKER_URL=redis://redis:6379/0
AGENTBOOK_CELERY_RESULT_BACKEND=redis://redis:6379/1

# ── LLM ────────────────────────────────────────────────────────────────────────
AGENTBOOK_OLLAMA_BASE_URL=http://host.docker.internal:11434
AGENTBOOK_LLM_LOCAL_MODEL=qwen2.5:7b
# Gateway fallback (judge, handwriting VLM khi cần)
OPENAI_API_KEY=sk-CHANGE_ME

# ── Storage ────────────────────────────────────────────────────────────────────
AGENTBOOK_RAW_DATA_DIR=/app/data/raw
AGENTBOOK_PROCESSED_DATA_DIR=/app/data/processed
